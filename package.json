{
  "name": "aeris-typhoon-terminal",
  "version": "0.1.0",
  "private": true,
  "description": "Palantir Terminal for Typhoon Resilience in the Philippines. Region-locked disaster response dashboard with live satellite, radar, hazard maps, and crowdsourced incident reporting.",
  "scripts": {
    "dev": "next dev",
    "dev:3001": "next dev -p 3001",
    "dev:3002": "next dev -p 3002",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "jest --runInBand",
    "test:coverage": "jest --runInBand --coverage",
    "predeploy": "npm run typecheck && npm test && npm run build && npm run test:e2e",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium",
    "postinstall": "node scripts/copy-piper-vendor.mjs",
    "smoke:reports": "node scripts/smoke_supabase_reports.mjs",
    "smoke:reports:insert": "node scripts/smoke_supabase_reports.mjs --insert",
    "smoke:mint": "npx tsx scripts/mint-testnet.ts",
    "deploy:contract": "npx tsx scripts/deploy-aeris-reports.ts",
    "vercel:whoami": "npx vercel whoami",
    "vercel:ls": "npx vercel ls",
    "vercel:pull": "npx vercel pull --yes",
    "vercel:deploy:prod": "npx vercel deploy --prod --yes"
  },
  "dependencies": {
    "@animocabrands/minds-client-lib": "^0.1.0",
    "@mintplex-labs/piper-tts-web": "^1.0.4",
    "@pixiv/three-vrm": "^3.5.2",
    "@privy-io/node": "^0.21.0",
    "@privy-io/react-auth": "^3.29.2",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.1",
    "@turf/bbox": "^7.1.0",
    "@turf/buffer": "^7.3.5",
    "@turf/helpers": "^7.1.0",
    "@vercel/kv": "^3.0.0",
    "clsx": "^2.1.1",
    "lucide-react": "^1.14.0",
    "maplibre-gl": "^4.7.1",
    "next": "^15.5.18",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.169.0",
    "viem": "^2.51.0"
  },
  "devDependencies": {
    "@openzeppelin/contracts": "^5.6.1",
    "@playwright/test": "^1.51.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.7.5",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.169.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.5.18",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "postcss": "^8.5.10",
    "solc": "^0.8.24",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": "22.x"
  },
  "overrides": {
    "glob": "^10.5.0",
    "tmp": "^0.2.7",
    "postcss": "^8.5.10"
  }
}
