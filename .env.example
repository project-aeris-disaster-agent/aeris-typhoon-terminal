# Vercel KV (Redis) - for incident reports and API cache
# Obtain from Vercel dashboard after provisioning KV
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# Shared Supabase intake (optional, preferred for AERIS Chat reports)
# Use the same project as AERIS CHAT/06 AERIS CHAT.
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: MapTiler key for enhanced base tiles (OSM works without)
# NEXT_PUBLIC_MAPTILER_KEY=

# YouTube Data API v3 (optional) — if set, used for live + embeddable metadata.
# Without a key, News Livestreams still works: we detect live via /@handle/live + page JSON.
# YOUTUBE_API_KEY=

# Optional: Feature flag to disable writes in dev
# ENABLE_REPORTS=true

# AGENT AERIS companion proxy (optional; required for in-panel AI chat)
# Point to the Flask/LLM backend used by AERIS CHAT, e.g. http://localhost:8000
AERIS_CHAT_API_BASE_URL=
# Optional bearer token; falls back to LLM_API_KEY when present.
AERIS_CHAT_API_KEY=
