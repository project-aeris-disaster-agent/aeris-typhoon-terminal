# Vercel KV (Redis) - for incident reports and API cache
# Obtain from Vercel dashboard after provisioning KV
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# Shared Supabase intake (optional, preferred for AERIS Chat reports)
# Use the same project as AERIS CHAT/06 AERIS CHAT.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Privy dashboard login (primary: Google, wallet, SMS)
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_SECRET=
# Optional: paste from Privy Dashboard to avoid network fetch on every verify
# PRIVY_JWT_VERIFICATION_KEY=

# Dashboard phone OTP gate (Supabase fallback; requires Supabase Auth phone provider)
# Set true locally to bypass login during development.
# DASHBOARD_AUTH_DISABLED=true

# AI report triage cron + internal worker auth
# Generate with: openssl rand -hex 32
# This same value MUST be set in AERIS CHAT (.env) so it can post real-time
# triage requests to /api/internal/triage when a new disaster report is filed.
INTERNAL_TRIAGE_SECRET=

# Optional: MapTiler key for enhanced base tiles (OSM works without)
# NEXT_PUBLIC_MAPTILER_KEY=

# Map search geocoding (Nominatim usage policy requires a contact email in User-Agent)
# NOMINATIM_CONTACT_EMAIL=ops@your-org.example
#
# Manual geocode smoke tests (dev server + map search bar):
# 1. Address: "123 Rizal Avenue Quezon City" -> Street/Address label, zoom 16-17
# 2. Place: "Barangay Holy Spirit Quezon City" -> Barangay label, zoom ~14.5
# 3. City: "Cebu City" -> City label, zoom ~12
# 4. Mixed: "Rizal" -> interleaved streets and places in dropdown
# 5. Map bias: pan to Visayas, search a generic name -> Visayas-heavy results
# 6. Network tab: no direct requests to nominatim.openstreetmap.org from browser

# YouTube Data API v3 (optional) — if set, used for live + embeddable metadata.
# Without a key, News Livestreams still works: we detect live via /@handle/live + page JSON.
# Feeds are cached in Supabase (youtube_feed_channel_cache); one worker refreshes stale rows.
# YOUTUBE_API_KEY=

# Requires NEXT_PUBLIC_SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY for shared feed cache.

# Optional: Feature flag to disable writes in dev
# ENABLE_REPORTS=true

# =====================================================================
# AGENT AERIS backend (required for in-panel AI chat, AI triage, and
# automated weather briefs). Points at the AERIS CHAT deployment which
# implements the frozen /api/llm/chat contract (see AERIS CHAT
# docs/AGENT_CONTRACT.md and this repo's docs/AGENT_BACKEND.md).
#
# Local dev:        http://localhost:3001
# Production:       https://<your-aeris-chat>.vercel.app  (no trailing slash)
# =====================================================================
AERIS_CHAT_API_BASE_URL=
# Bearer token sent to AERIS CHAT. MUST be identical to LLM_API_KEY on the
# AERIS CHAT project. Falls back to LLM_API_KEY env if AERIS_CHAT_API_KEY is
# unset, but setting it explicitly is preferred for clarity.
AERIS_CHAT_API_KEY=

# Note: the model itself (NVIDIA_API_KEY, LLM_MODEL) is configured on AERIS
# CHAT, not here. The dashboard never calls NVIDIA directly.
# Proxy timeout for POST /api/agent-aeris/chat → AERIS CHAT (default 60000 ms).
# AGENT_CHAT_TIMEOUT_MS=60000

# Agent AERIS avatar TTS (browser-only, in-panel voice + lip-sync)
# piper — offline neural voice (en_US-hfc_female-medium); first use downloads ~20–40MB
# web-speech — OS speechSynthesis fallback (no extra download)
NEXT_PUBLIC_AGENT_TTS=piper

# National weather report cron (Vercel Cron → GET /api/cron/weather-reports, daily)
# AI report triage cron (Vercel Cron → GET /api/cron/triage). vercel.json ships
# a Hobby-safe daily schedule ("0 9 * * *"). On Pro you can edit it to e.g.
# "*/5 * * * *" for near-real-time backfill. Real-time triage already runs
# inline from AERIS CHAT via /api/internal/triage, so cron is a safety-net.
# Generate with: openssl rand -hex 32
CRON_SECRET=

# --- AI triage cron tuning ---
# Defaults picked for Vercel Hobby (10s function ceiling, ~5 reports per tick).
# On Pro, raise batch size to drain larger backlogs per run. To increase the
# function timeout itself, edit `export const maxDuration` in
# app/api/cron/triage/route.ts and app/api/internal/triage/route.ts to a static
# literal (Next.js does not support runtime overrides here).
# TRIAGE_CRON_BATCH_SIZE=5        # reports per cron tick (1-100)
# TRIAGE_CRON_SAFETY_MS=1500      # ms before deadline to stop fetching new work
